# CAIRN Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Contract Address (your deployed CairnTaskMVP address)
NEXT_PUBLIC_CAIRN_CONTRACT_ADDRESS=

# Chain Configuration (84532 = Base Sepolia)
NEXT_PUBLIC_CHAIN_ID=84532

# Demo Mode (enables demo controls)
NEXT_PUBLIC_DEMO_MODE=true

# IPFS Gateway for checkpoint viewing
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs
