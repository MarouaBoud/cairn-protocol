# CAIRN Protocol MVP - Contracts Environment Variables
# Copy to .env and fill in values

# ═══════════════════════════════════════════════════════════════════════════════
# DEPLOYMENT
# ═══════════════════════════════════════════════════════════════════════════════

# Base Sepolia RPC URL
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Deployer private key (TESTNET ONLY - never commit mainnet keys!)
DEPLOYER_PRIVATE_KEY=0x...

# Contract owner address (receives admin control)
OWNER_ADDRESS=0x...

# Fee recipient address (receives protocol fees)
FEE_RECIPIENT_ADDRESS=0x...

# ═══════════════════════════════════════════════════════════════════════════════
# VERIFICATION
# ═══════════════════════════════════════════════════════════════════════════════

# Basescan API key for contract verification
BASESCAN_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# DEPLOYED CONTRACTS - Full Protocol (Base Sepolia)
# ═══════════════════════════════════════════════════════════════════════════════

# Full Protocol on Base Sepolia (Chain ID: 84532)
CAIRN_CORE_ADDRESS=0xB65596B21d670b6C670106C3e3c7E5FFf8E3A640
CAIRN_GOVERNANCE_ADDRESS=0x7A09567e0348889Cc14264bEcf08F8d72Dc6987f
