# CAIRN Protocol MVP - Full Environment Configuration
# Copy to .env and fill in values
# Hackathon: Synthesis 2026 | Chain: Base Sepolia | Deadline: March 23, 2026

# ═══════════════════════════════════════════════════════════════════════════════
# PHASE 1: CONTRACT DEPLOYMENT (Foundry)
# ═══════════════════════════════════════════════════════════════════════════════

# Base Sepolia RPC URL
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Deployer wallet private key (TESTNET ONLY - never commit mainnet keys!)
DEPLOYER_PRIVATE_KEY=0x...

# Contract owner address (receives admin control of CairnTaskMVP)
OWNER_ADDRESS=0x...

# Fee recipient address (receives 0.5% protocol fees from settlements)
FEE_RECIPIENT_ADDRESS=0x...

# Basescan API key for contract verification
# Get from: https://basescan.org/myapikey
BASESCAN_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# PHASE 2: SDK (Python)
# ═══════════════════════════════════════════════════════════════════════════════

# Contract address (filled after Phase 1 deployment)
CAIRN_CONTRACT_ADDRESS=0x...

# Pinata JWT for IPFS checkpoint storage
# Get from: https://app.pinata.cloud/developers/api-keys
PINATA_JWT=eyJ...

# ═══════════════════════════════════════════════════════════════════════════════
# PHASE 3: FRONTEND (Next.js)
# ═══════════════════════════════════════════════════════════════════════════════

# Public env vars (exposed to browser - NEXT_PUBLIC_ prefix required)
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_CAIRN_CONTRACT_ADDRESS=0x...
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# WalletConnect Project ID (for wallet connections)
# Get from: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ═══════════════════════════════════════════════════════════════════════════════
# PHASE 4: VERCEL DEPLOYMENT (Optional)
# ═══════════════════════════════════════════════════════════════════════════════

# Vercel token for preview deployments
# Get from: https://vercel.com/account/tokens
VERCEL_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════════
# DEMO AGENTS (for testing)
# ═══════════════════════════════════════════════════════════════════════════════

# Primary agent wallet (for demo)
PRIMARY_AGENT_PRIVATE_KEY=0x...

# Fallback agent wallet (for demo)
FALLBACK_AGENT_PRIVATE_KEY=0x...

# Operator wallet (submits tasks)
OPERATOR_PRIVATE_KEY=0x...
